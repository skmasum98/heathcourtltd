---
import Layout from '../layouts/Layout.astro';

const values = [
  {
    title: "Quality Assurance",
    description: "Every product in our warehouse undergoes a strict quality check to ensure it meets the standards your customers expect.",
    icon: "🛡️"
  },
  {
    title: "Competitive Pricing",
    description: "By maintaining strong relationships with manufacturers, we pass on significant bulk savings to our retail partners.",
    icon: "💰"
  },
  {
    title: "Reliable Logistics",
    description: "Located in Mildenhall, our distribution center is positioned for rapid dispatch and dependable delivery across the UK.",
    icon: "🚛"
  }
];

// Add a highlight stat for visual interest
const stats = [
  { value: "450+", label: "Products in Stock" },
  { value: "50+", label: "Trusted Partners" },
  { value: "24h", label: "Dispatch Time" },
  { value: "100%", label: "Quality Checked" }
];
---

<Layout title="About Us | Heath Court Ltd - UK Household Wholesale">
  <main class="bg-white overflow-hidden">
    <!-- 1. HEADER SECTION - Enhanced with gradient and decorative elements -->
    <section class="relative bg-linear-to-br from-slate-900 via-slate-800 to-slate-900 py-20 md:py-28 overflow-hidden">
      <!-- Decorative background elements -->
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 left-0 w-96 h-96 bg-blue-500 rounded-full filter blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-500 rounded-full filter blur-3xl translate-x-1/2 translate-y-1/2"></div>
      </div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 mb-6">
          <span class="text-blue-400 text-sm font-medium">📍 Mildenhall, UK</span>
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white tracking-tight">
          About <span class="bg-linear-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">Heath Court Ltd</span>
        </h1>
        <p class="mt-6 text-xl text-slate-300 max-w-3xl mx-auto leading-relaxed">
          Your trusted partner in wholesale household goods distribution, serving retailers and businesses across the UK with excellence since day one.
        </p>
      </div>
    </section>

    <!-- Stats Section - New addition for social proof -->
    <section class="py-12 bg-white border-b border-slate-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {stats.map(stat => (
            <div class="text-center group">
              <div class="text-3xl md:text-4xl font-bold text-slate-900 mb-1 group-hover:text-blue-600 transition-colors">
                {stat.value}
              </div>
              <div class="text-sm text-slate-500 uppercase tracking-wider">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 2. MISSION & STORY SECTION - Enhanced with better imagery and layout -->
    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row items-center gap-16">
          <div class="lg:w-1/2 order-2 lg:order-1">
            <div class="inline-flex items-center gap-2 bg-blue-50 rounded-full px-4 py-2 mb-6">
              <span class="text-blue-600 text-sm font-medium">Our Heritage</span>
            </div>
            <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6 tracking-tight">
              Bridging the gap between <span class="text-blue-600">quality manufacturing</span> and retail success.
            </h2>
            <div class="space-y-5 text-lg text-slate-600 leading-relaxed">
              <p class="border-l-4 border-blue-500 pl-6 italic text-slate-700">
                "Based in the heart of Suffolk, Heath Court Ltd started with a simple goal: to provide high-quality household goods at prices that allow businesses to grow."
              </p>
              <p>
                We understand the challenges of modern retail, and we aim to be the most reliable link in your supply chain. From our warehouse at 82 James Carter Road, we manage a diverse inventory ranging from essential kitchenware to decorative home accents.
              </p>
              <p class="font-medium text-slate-800">
                Our focus has always been on consistency—consistent quality, consistent pricing, and consistent delivery.
              </p>
            </div>
          </div>
          <div class="lg:w-1/2 order-1 lg:order-2">
            <div class="relative">
              <div class="absolute -inset-4 bg-linear-to-r from-blue-500/20 to-purple-500/20 rounded-3xl blur-2xl"></div>
              <div class="relative grid grid-cols-2 gap-4">
                <img 
                  src="https://images.unsplash.com/photo-1590602847861-f357a9332bbc?auto=format&fit=crop&q=80&w=600&h=800" 
                  alt="Household Items" 
                  class="rounded-2xl shadow-xl object-cover h-80 w-full mt-12 hover:scale-[1.02] transition-transform duration-500"
                />
                <img 
                  src="https://images.unsplash.com/photo-1550989460-0adf9ea622e2?auto=format&fit=crop&q=80&w=600&h=800" 
                  alt="Wholesale Warehouse" 
                  class="rounded-2xl shadow-xl object-cover h-80 w-full hover:scale-[1.02] transition-transform duration-500"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. CORE VALUES SECTION - Enhanced with glassmorphism and hover effects -->
    <section class="py-24 bg-linear-to-br from-slate-900 via-slate-800 to-slate-900 relative overflow-hidden">
      <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1556761175-4b46a572b786?auto=format&fit=crop&q=80&w=2000')] bg-cover bg-center opacity-5"></div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 mb-6">
            <span class="text-blue-400 text-sm font-medium">Why Choose Us</span>
          </div>
          <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Why Partner With Us?</h2>
          <div class="w-24 h-1 bg-linear-to-r from-blue-500 to-purple-500 mx-auto mt-4 rounded-full"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {values.map((value, index) => (
            <div class="group bg-white/5 backdrop-blur-sm p-8 rounded-2xl border border-white/10 hover:border-blue-500/50 transition-all duration-300 hover:-translate-y-2">
              <div class="text-5xl mb-6 group-hover:scale-110 transition-transform duration-300 inline-block">{value.icon}</div>
              <h3 class="text-2xl font-bold text-white mb-4">{value.title}</h3>
              <p class="text-slate-300 leading-relaxed">
                {value.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. LOCATION & LOGISTICS SECTION - Enhanced with modern card design -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative bg-linear-to-br from-blue-50 to-indigo-50 rounded-3xl overflow-hidden shadow-xl">
          <div class="absolute top-0 right-0 w-64 h-64 bg-blue-200 rounded-full filter blur-3xl opacity-30"></div>
          <div class="absolute bottom-0 left-0 w-64 h-64 bg-purple-200 rounded-full filter blur-3xl opacity-30"></div>
          <div class="relative p-8 md:p-16 flex flex-col lg:flex-row items-center justify-between gap-12">
            <div class="lg:w-1/2">
              <div class="inline-flex items-center gap-2 bg-white/80 rounded-full px-4 py-2 mb-6">
                <span class="text-blue-600 text-sm font-medium">📍 Strategic Location</span>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6 tracking-tight">Strategic UK Distribution</h2>
              <p class="text-lg text-slate-700 mb-8 leading-relaxed">
                Our headquarters at <span class="font-semibold text-blue-600">Unit A 82 James Carter Road, Mildenhall</span>, is perfectly situated to serve the UK's logistics network. This central location allows us to maintain a large stock inventory and process orders with industry-leading speed.
              </p>
              <div class="space-y-4">
                <div class="flex items-center gap-4 p-3 bg-white/60 rounded-xl backdrop-blur-sm">
                  <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center text-sm font-bold shadow-lg">1</div>
                  <span class="text-slate-800 font-medium">Rapid processing of bulk orders</span>
                </div>
                <div class="flex items-center gap-4 p-3 bg-white/60 rounded-xl backdrop-blur-sm">
                  <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center text-sm font-bold shadow-lg">2</div>
                  <span class="text-slate-800 font-medium">Direct access to major UK freight routes</span>
                </div>
                <div class="flex items-center gap-4 p-3 bg-white/60 rounded-xl backdrop-blur-sm">
                  <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center text-sm font-bold shadow-lg">3</div>
                  <span class="text-slate-800 font-medium">On-site quality control inspections</span>
                </div>
              </div>
            </div>
            <div class="lg:w-1/3 w-full">
              <div class="bg-white p-8 rounded-2xl shadow-2xl border border-slate-100 hover:shadow-3xl transition-shadow duration-300">
                <div class="text-center">
                  <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                  </div>
                  <p class="text-slate-500 uppercase tracking-widest text-xs font-bold mb-2">Visit Our Warehouse</p>
                  <h4 class="text-xl font-bold text-slate-900 mb-4">Bury St. Edmunds, England</h4>
                  <p class="text-slate-600 text-sm mb-6">Unit A 82 James Carter Road, Mildenhall, IP28 7DE</p>
                  <a 
                    href="/contact" 
                    class="inline-block w-full py-3 bg-linear-to-r from-slate-900 to-slate-800 text-white font-bold rounded-xl hover:from-blue-600 hover:to-blue-700 transition-all duration-300 shadow-md hover:shadow-lg"
                  >
                    Schedule a Visit →
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 5. FINAL CALL TO ACTION - Enhanced with modern design -->
    <section class="py-24 bg-linear-to-r from-slate-50 to-white text-center relative overflow-hidden">
      <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&q=80&w=2000')] bg-cover bg-center opacity-5"></div>
      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="inline-flex items-center gap-2 bg-blue-50 rounded-full px-4 py-2 mb-6">
          <span class="text-blue-600 text-sm font-medium">Ready to grow?</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6 tracking-tight">Want to see our full product range?</h2>
        <p class="text-xl text-slate-600 mb-10 max-w-2xl mx-auto">Explore our extensive wholesale catalog and discover the perfect products for your business.</p>
        <a 
          href="/products" 
          class="group inline-flex items-center gap-2 bg-linear-to-r from-blue-600 to-blue-700 text-white text-lg font-semibold px-8 py-4 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5"
        >
          View the Wholesale Catalog 
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </section>
  </main>
</Layout>