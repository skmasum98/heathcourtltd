---

<Layout title="Wholesale Catalog | Heath Court Ltd - UK Household Goods Distributor">
  <main class="bg-white min-h-screen">
    <!-- 1. PAGE HEADER - Enhanced with stats -->
    <section class="relative bg-linear-to-br from-slate-900 via-slate-800 to-slate-900 py-16 md:py-24 overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 left-0 w-96 h-96 bg-blue-500 rounded-full filter blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-500 rounded-full filter blur-3xl translate-x-1/2 translate-y-1/2"></div>
      </div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 mb-6">
          <span class="text-blue-400 text-sm font-medium">📦 Bulk Orders Welcome</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          Wholesale <span class="bg-linear-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">Catalog</span>
        </h1>
        <p class="text-slate-300 text-lg max-w-2xl mx-auto mb-8">
          High-quality household essentials available for bulk order. 
          Register for a trade account to view full pricing.
        </p>
        <div class="flex flex-wrap justify-center gap-6 text-center">
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-3">
            <div class="text-2xl font-bold text-white">{products.length + 400}+</div>
            <div class="text-xs text-slate-400 uppercase tracking-wide">Products</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-3">
            <div class="text-2xl font-bold text-white">{featuredCount + 300}</div>
            <div class="text-xs text-slate-400 uppercase tracking-wide">In Stock</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-3">
            <div class="text-2xl font-bold text-white">84+</div>
            <div class="text-xs text-slate-400 uppercase tracking-wide">Categories</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. FILTER & TOOLS BAR - Enhanced with active filter state -->
    <section class="sticky top-0 z-40 bg-white border-b border-slate-200 shadow-sm py-4 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col lg:flex-row justify-between items-center gap-4">
          <!-- Category Pills with active state styling -->
          <div class="flex gap-2 overflow-x-auto pb-2 lg:pb-0 no-scrollbar w-full lg:w-auto">
            {categories.map((cat, idx) => (
              <button 
                class={`category-filter whitespace-nowrap px-6 py-2 rounded-full text-sm font-medium transition-all duration-200 ${
                  idx === 0 
                    ? 'bg-blue-600 text-white shadow-md shadow-blue-200' 
                    : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-100'
                }`}
                data-category={cat.toLowerCase()}
              >
                {cat}
              </button>
            ))}
          </div>
          
          <!-- Search Bar with icon -->
          <div class="relative w-full lg:w-80">
            <input 
              type="text" 
              id="search-input"
              placeholder="Search SKU or Product..." 
              class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all bg-slate-50 focus:bg-white" 
            />
            <svg class="w-5 h-5 absolute left-3 top-2.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
        </div>
        
        <!-- Active filters display -->
        <div id="active-filters" class="flex items-center gap-2 mt-3 text-xs text-slate-500">
          <span>Showing:</span>
          <span id="product-count" class="font-semibold text-blue-600">{products.length}</span>
          <span>products</span>
        </div>
      </div>
    </section>

    <!-- 3. PRODUCT GRID - Enhanced with better cards and animations -->
    <section class="py-12 px-4">
      <div class="max-w-7xl mx-auto">
        <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8">
          {products.map((product, index) => (
            <div 
              class="product-card group bg-white border border-slate-200 rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 flex flex-col"
              data-category={product.category.toLowerCase()}
              data-name={product.name.toLowerCase()}
              data-id={product.id.toLowerCase()}
              data-index={index}
            >
              <!-- Image Container with badge -->
              <div class="relative aspect-square bg-linear-to-br from-slate-50 to-slate-100 overflow-hidden">
                <img 
                  src={product.image} 
                  alt={product.name} 
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" 
                  loading="lazy"
                />
                <div class="absolute top-3 left-3 flex gap-2">
                  <span class="bg-white/95 backdrop-blur-sm px-2 py-1 rounded-lg text-[10px] font-bold text-slate-700 shadow-sm border border-slate-100">
                    SKU: {product.id}
                  </span>
                  {!product.inStock && (
                    <span class="bg-red-500 text-white px-2 py-1 rounded-lg text-[10px] font-bold shadow-sm">
                      Out of Stock
                    </span>
                  )}
                </div>
                {product.inStock && (
                  <div class="absolute top-3 right-3">
                    <span class="bg-green-500 text-white px-2 py-1 rounded-lg text-[10px] font-bold shadow-sm">
                      In Stock
                    </span>
                  </div>
                )}
              </div>

              <!-- Product Info -->
              <div class="p-5 flex flex-col grow">
                <div class="mb-2">
                  <span class="text-blue-600 text-xs font-bold uppercase tracking-wider bg-blue-50 px-2 py-1 rounded">
                    {product.category}
                  </span>
                </div>
                <h3 class="text-slate-900 font-bold text-base md:text-lg mb-3 line-clamp-2 min-h-14">
                  {product.name}
                </h3>
                
                <!-- B2B Details -->
                <div class="grid grid-cols-2 gap-3 py-3 border-y border-slate-100 mb-4">
                  <div>
                    <p class="text-slate-400 text-[10px] uppercase font-bold tracking-wider">Min. Order</p>
                    <p class="text-slate-800 font-semibold text-sm">{product.moq}</p>
                  </div>
                  <div>
                    <p class="text-slate-400 text-[10px] uppercase font-bold tracking-wider">Carton Size</p>
                    <p class="text-slate-800 font-semibold text-sm">{product.carton}</p>
                  </div>
                </div>

                <a 
                  href="/contact" 
                  class={`block w-full text-center py-3 rounded-xl font-bold text-sm transition-all duration-300 shadow-sm ${
                    product.inStock 
                      ? 'bg-linear-to-r from-slate-900 to-slate-800 text-white hover:from-blue-600 hover:to-blue-700 hover:shadow-md' 
                      : 'bg-slate-100 text-slate-400 cursor-not-allowed'
                  }`}
                  {...(!product.inStock && { onClick: (e: Event) => e.preventDefault() })}
                >
                  {product.inStock ? 'Inquire for Pricing →' : 'Contact for Restock'}
                </a>
              </div>
            </div>
          ))}
        </div>
        
        <!-- Empty state -->
        <div id="empty-state" class="hidden text-center py-16">
          <div class="text-6xl mb-4">🔍</div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">No products found</h3>
          <p class="text-slate-500">Try adjusting your search or filter to find what you're looking for.</p>
          <button id="reset-filters" class="mt-4 text-blue-600 font-medium hover:underline">Reset all filters</button>
        </div>
      </div>
    </section>

    <!-- 4. FEATURED BANNER - Enhanced with gradient -->
    <section class="py-16 bg-linear-to-r from-blue-600 to-indigo-600">
      <div class="max-w-4xl mx-auto text-center px-4">
        <div class="inline-flex items-center gap-2 bg-white/20 rounded-full px-4 py-2 mb-6">
          <span class="text-white text-sm font-medium">💡 Need Something Specific?</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Don't see what you're looking for?</h2>
        <p class="text-blue-100 text-lg mb-8 max-w-2xl mx-auto">
          We have hundreds of additional products arriving weekly at our Mildenhall warehouse. 
          Contact our sourcing team with your specific requirements.
        </p>
        <a 
          href="/contact" 
          class="inline-flex items-center gap-2 bg-white text-blue-600 font-bold px-8 py-4 rounded-xl hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 group"
        >
          Contact Sourcing Team 
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </section>

    <!-- 5. BULK ORDER INFO - New section -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center p-6">
            <div class="text-3xl mb-3">🚚</div>
            <h3 class="font-bold text-slate-900 mb-2">Free Delivery on Bulk Orders</h3>
            <p class="text-slate-500 text-sm">Orders over £500 qualify for free UK delivery</p>
          </div>
          <div class="text-center p-6">
            <div class="text-3xl mb-3">📋</div>
            <h3 class="font-bold text-slate-900 mb-2">Trade Account Benefits</h3>
            <p class="text-slate-500 text-sm">Exclusive pricing, credit terms, and priority support</p>
          </div>
          <div class="text-center p-6">
            <div class="text-3xl mb-3">✅</div>
            <h3 class="font-bold text-slate-900 mb-2">Quality Guaranteed</h3>
            <p class="text-slate-500 text-sm">All products undergo strict quality control checks</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  /* Hide scrollbar but allow scrolling */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  
  /* Line clamp utility */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  /* Animation for product cards */
  .product-card {
    animation: fadeInUp 0.5s ease-out forwards;
    opacity: 0;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Stagger animation delay for cards */
  .product-card {
    animation-delay: calc(var(--index, 0) * 0.03s);
  }
</style>

<script>
  // Product filtering functionality
  document.addEventListener('DOMContentLoaded', () => {
    const products = document.querySelectorAll('.product-card');
    const categoryButtons = document.querySelectorAll('.category-filter');
    const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
    const productCountSpan = document.getElementById('product-count');
    const emptyState = document.getElementById('empty-state');
    const productGrid = document.getElementById('product-grid');
    const resetBtn = document.getElementById('reset-filters');
    
    let activeCategory = 'all';
    let searchTerm = '';
    
    // Set animation delays
    products.forEach((card, idx) => {
      const htmlCard = card as HTMLElement;
      htmlCard.style.setProperty('--index', idx.toString());
    });
    
    function filterProducts() {
      let visibleCount = 0;
      
      products.forEach(card => {
        const htmlCard = card as HTMLElement;
        const category = htmlCard.dataset.category;
        const name = htmlCard.dataset.name;
        const id = htmlCard.dataset.id;
        
        const matchesCategory = activeCategory === 'all' || category === activeCategory;
        const matchesSearch = searchTerm === '' || 
          name?.includes(searchTerm) || 
          id?.includes(searchTerm);
        
        if (matchesCategory && matchesSearch) {
          htmlCard.style.display = 'flex';
          visibleCount++;
        } else {
          htmlCard.style.display = 'none';
        }
      });
      
      // Update count
      if (productCountSpan) {
        productCountSpan.textContent = visibleCount.toString();
      }
      
      // Show/hide empty state
      if (visibleCount === 0) {
        productGrid?.classList.add('hidden');
        emptyState?.classList.remove('hidden');
      } else {
        productGrid?.classList.remove('hidden');
        emptyState?.classList.add('hidden');
      }
    }
    
    // Category filter click handler
    categoryButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update active button styling
        categoryButtons.forEach(b => {
          b.classList.remove('bg-blue-600', 'text-white', 'shadow-md', 'shadow-blue-200');
          b.classList.add('bg-white', 'border', 'border-slate-200', 'text-slate-600');
        });
        btn.classList.remove('bg-white', 'border', 'border-slate-200', 'text-slate-600');
        btn.classList.add('bg-blue-600', 'text-white', 'shadow-md', 'shadow-blue-200');
        
        // Update active category
        const htmlBtn = btn as HTMLElement;
        activeCategory = htmlBtn.dataset.category || 'all';
        filterProducts();
      });
    });
    
    // Search input handler
    if (searchInput) {
      searchInput.addEventListener('input', (e: Event) => {
        const target = e.target as HTMLInputElement;
        searchTerm = target.value.toLowerCase();
        filterProducts();
      });
    }
    
    // Reset filters
    if (resetBtn && searchInput) {
      resetBtn.addEventListener('click', () => {
        searchInput.value = '';
        searchTerm = '';
        activeCategory = 'all';
        
        // Reset category button styling
        categoryButtons.forEach(btn => {
          btn.classList.remove('bg-blue-600', 'text-white', 'shadow-md', 'shadow-blue-200');
          btn.classList.add('bg-white', 'border', 'border-slate-200', 'text-slate-600');
        });
        const firstBtn = categoryButtons[0];
        if (firstBtn) {
          firstBtn.classList.remove('bg-white', 'border', 'border-slate-200', 'text-slate-600');
          firstBtn.classList.add('bg-blue-600', 'text-white', 'shadow-md', 'shadow-blue-200');
        }
        
        filterProducts();
      });
    }
    
    // Initial filter to set proper state
    filterProducts();
  });
</script>