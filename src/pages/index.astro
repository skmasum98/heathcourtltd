---
import Layout from '../layouts/Layout.astro';


// Category Data
const categories = [
  { title: 'Kitchenware', icon: '🍳', desc: 'Bulk cookware, utensils, and storage.' },
  { title: 'Cleaning Supplies', icon: '🧼', desc: 'Commercial grade soaps and equipment.' },
  { title: 'Laundry Care', icon: '🧺', desc: 'Detergents and laundry room essentials.' },
  { title: 'Home Decor', icon: '🖼️', desc: 'Trendy accents and interior goods.' },
  { title: 'Bathroom Essentials', icon: '🚿', desc: 'Towels, mats, and toiletries.' },
  { title: 'Garden & Outdoor', icon: '🪴', desc: 'Seasonal goods and outdoor utility.' },
];
---

<Layout title="Heath Court Ltd | UK Household Goods Wholesale">
	

	<main>
		<!-- 1. HERO SECTION -->
		<section class="relative bg-slate-900 py-24 lg:py-32 overflow-hidden">
      <!-- Background pattern/image placeholder -->
      <div class="absolute inset-0 opacity-10 bg-[url('https://raw.githubusercontent.com/skmasum98/heathcourtltd/refs/heads/master/public/hero.jpeg')]"></div>
      
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
				<div class="lg:w-2/3">
					<h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight leading-tight">
						Premium Wholesale <span class="text-blue-500">Household Goods</span> for Your Business.
					</h1>
					<p class="mt-6 text-xl text-slate-300 max-w-2xl leading-relaxed">
						Supplying retailers, hotels, and businesses across the UK with high-quality household essentials at competitive bulk pricing. Reliable delivery from our Mildenhall warehouse.
					</p>
					<div class="mt-10 flex flex-col sm:flex-row gap-4">
						<a href="/products" class="px-8 py-4 bg-blue-600 text-white font-bold rounded-lg text-center hover:bg-blue-700 transition-all shadow-lg">
							Browse Catalog
						</a>
						<a href="/contact" class="px-8 py-4 bg-white text-slate-900 font-bold rounded-lg text-center hover:bg-slate-100 transition-all">
							Become a Partner
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- 2. KEY STATS / TRUST BAR -->
		<section class="bg-blue-600 py-8">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center text-white">
					<div>
						<p class="text-3xl font-bold">1000+</p>
						<p class="text-sm opacity-80 uppercase tracking-widest">Products</p>
					</div>
					<div>
						<p class="text-3xl font-bold">UK Wide</p>
						<p class="text-sm opacity-80 uppercase tracking-widest">Shipping</p>
					</div>
					<div>
						<p class="text-3xl font-bold">B2B Only</p>
						<p class="text-sm opacity-80 uppercase tracking-widest">Trade Prices</p>
					</div>
					<div>
						<p class="text-3xl font-bold">Mildenhall</p>
						<p class="text-sm opacity-80 uppercase tracking-widest">Warehouse</p>
					</div>
				</div>
			</div>
		</section>

		<!-- 3. PRODUCT CATEGORIES GRID -->
		<section class="py-24 bg-slate-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-4xl font-bold text-slate-900">Our Wholesale Categories</h2>
					<p class="mt-4 text-slate-600 max-w-2xl mx-auto">We stock a wide variety of household essentials to keep your shelves full and your customers happy.</p>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{categories.map(cat => (
						<div class="group p-8 bg-white border border-slate-200 rounded-2xl hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
							<div class="text-4xl mb-4">{cat.icon}</div>
							<h3 class="text-xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors">{cat.title}</h3>
							<p class="mt-2 text-slate-600">{cat.desc}</p>
							<a href={`/products/${cat.title.toLowerCase()}`} class="mt-4 inline-flex items-center text-blue-600 font-semibold text-sm">
								Explore {cat.title} 
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
								</svg>
							</a>
						</div>
					))}
				</div>
			</div>
		</section>

    <!-- 4. WHO WE ARE / VALUE PROP -->
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row items-center gap-16">
          <div class="lg:w-1/2">
            <img src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&q=80&w=800" alt="Warehouse Distribution" class="rounded-2xl shadow-2xl" />
          </div>
          <div class="lg:w-1/2">
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight">Reliable Household Distribution Based in Mildenhall</h2>
            <p class="mt-6 text-lg text-slate-600 leading-relaxed">
              Heath Court Ltd has established itself as a cornerstone for household product distribution in the Suffolk area. From our central location in James Carter Road, we efficiently manage logistics to ensure timely delivery across the United Kingdom.
            </p>
            <ul class="mt-8 space-y-4">
              {['Competitive Bulk Pricing', 'Quality Checked Inventory', 'Next-Day Dispatch Available', 'Dedicated Account Managers'].map(item => (
                <li class="flex items-center text-slate-900 font-medium">
                  <svg class="h-6 w-6 text-green-500 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

		<!-- 5. CALL TO ACTION (CTA) -->
		<section class="py-20 bg-blue-600">
			<div class="max-w-5xl mx-auto px-4 text-center">
				<h2 class="text-3xl md:text-5xl font-bold text-white mb-8">Ready to Stock Your Shelves?</h2>
				<p class="text-xl text-blue-100 mb-10">Request our latest wholesale price list and catalog today.</p>
				<a href="/contact" class="inline-block px-10 py-5 bg-white text-blue-600 font-bold text-lg rounded-full hover:bg-slate-100 transition-all shadow-xl">
					Get a Quote Now
				</a>
			</div>
		</section>
	</main>

	
</Layout>