---
import Layout from '../layouts/Layout.astro';

const contactInfo = {
  address: "Unit A 82 James Carter Road, Mildenhall, Bury St. Edmunds, IP28 7DE",
  email: "info@heathcourtltd.com",
  phone: "+44 (0) 1638 XXX XXX", // Replace with actual number
  hours: "Mon - Fri: 09:00 - 17:30",
};

// Enhanced contact methods for better UX
const contactMethods = [
  {
    icon: "📞",
    title: "Call Us",
    details: contactInfo.phone,
    action: `tel:${contactInfo.phone.replace(/[^0-9+]/g, '')}`,
    description: "Speak directly with our wholesale team"
  },
  {
    icon: "✉️",
    title: "Email Us",
    details: contactInfo.email,
    action: `mailto:${contactInfo.email}`,
    description: "Get a response within 24 hours"
  },
  {
    icon: "📍",
    title: "Visit Us",
    details: contactInfo.address,
    action: "#map",
    description: "By appointment only"
  }
];
---

<Layout title="Contact Us | Heath Court Ltd - UK Wholesale Distributor">
  <main class="bg-white overflow-hidden">
    <!-- 1. HEADER - Enhanced with gradient and decorative elements -->
    <section class="relative bg-linear-to-br from-slate-900 via-slate-800 to-slate-900 py-20 md:py-28 overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 left-0 w-96 h-96 bg-blue-500 rounded-full filter blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-500 rounded-full filter blur-3xl translate-x-1/2 translate-y-1/2"></div>
      </div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 mb-6">
          <span class="text-blue-400 text-sm font-medium">📬 Let's Connect</span>
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white tracking-tight">
          Get in <span class="bg-linear-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">Touch</span>
        </h1>
        <p class="mt-6 text-xl text-slate-300 max-w-2xl mx-auto leading-relaxed">
          Inquire about bulk pricing, open a trade account, or schedule a warehouse visit. Our team is here to support your business.
        </p>
      </div>
    </section>

    <!-- 2. QUICK CONTACT METHODS - New section for better UX -->
    <section class="py-12 bg-white border-b border-slate-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {contactMethods.map(method => (
            <a 
              href={method.action} 
              class="group bg-slate-50 hover:bg-linear-to-br hover:from-blue-50 hover:to-indigo-50 rounded-2xl p-6 transition-all duration-300 border border-slate-100 hover:border-blue-200 text-center"
            >
              <div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300">{method.icon}</div>
              <h3 class="text-lg font-bold text-slate-900 mb-1">{method.title}</h3>
              <p class="text-slate-600 text-sm mb-2">{method.details}</p>
              <p class="text-slate-400 text-xs">{method.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. CONTACT GRID - Enhanced with modern design -->
    <section class="py-16 md:py-24 bg-slate-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          
          <!-- Column 1 & 2: Contact Form - Enhanced with better styling -->
          <div class="lg:col-span-2 bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden">
            <div class="bg-linear-to-r from-slate-900 to-slate-800 px-8 py-6">
              <h2 class="text-2xl font-bold text-white">Wholesale Inquiry Form</h2>
              <p class="text-slate-300 text-sm mt-1">Fill out the form and we'll get back to you within 24 hours</p>
            </div>
            
            <form action="#" method="POST" class="p-8 md:p-10">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="full-name" class="block text-sm font-semibold text-slate-700 mb-2">Full Name *</label>
                  <input 
                    type="text" 
                    id="full-name" 
                    name="full-name" 
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all bg-slate-50 focus:bg-white" 
                    placeholder="John Doe" 
                    required 
                  />
                </div>
                <div>
                  <label for="company-name" class="block text-sm font-semibold text-slate-700 mb-2">Company Name *</label>
                  <input 
                    type="text" 
                    id="company-name" 
                    name="company-name" 
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all bg-slate-50 focus:bg-white" 
                    placeholder="Retailers Ltd" 
                    required 
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-semibold text-slate-700 mb-2">Business Email *</label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all bg-slate-50 focus:bg-white" 
                    placeholder="john@company.com" 
                    required 
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-semibold text-slate-700 mb-2">Phone Number</label>
                  <input 
                    type="tel" 
                    id="phone" 
                    name="phone" 
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all bg-slate-50 focus:bg-white" 
                    placeholder="+44 0000 000000" 
                  />
                </div>
                <div class="md:col-span-2">
                  <label for="subject" class="block text-sm font-semibold text-slate-700 mb-2">Nature of Inquiry *</label>
                  <select 
                    id="subject" 
                    name="subject" 
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all bg-slate-50 focus:bg-white"
                    required
                  >
                    <option value="">Select an option</option>
                    <option>Request Price List / Catalog</option>
                    <option>Open a New Trade Account</option>
                    <option>Order Status Inquiry</option>
                    <option>Warehouse Visit Appointment</option>
                    <option>Bulk Order Quote</option>
                    <option>Other</option>
                  </select>
                </div>
                <div class="md:col-span-2">
                  <label for="message" class="block text-sm font-semibold text-slate-700 mb-2">Your Message *</label>
                  <textarea 
                    id="message" 
                    name="message" 
                    rows="5" 
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all bg-slate-50 focus:bg-white" 
                    placeholder="Please provide details about the products you are interested in, estimated order volume, or any specific requirements..." 
                    required
                  ></textarea>
                </div>
                <div class="md:col-span-2">
                  <button 
                    type="submit" 
                    class="w-full bg-linear-to-r from-blue-600 to-blue-700 text-white font-bold py-4 rounded-xl hover:from-blue-700 hover:to-blue-800 transition-all duration-300 shadow-lg shadow-blue-200 hover:shadow-xl transform hover:-translate-y-0.5"
                  >
                    Send Inquiry →
                  </button>
                  <p class="text-xs text-slate-400 text-center mt-4">
                    By submitting this form, you agree to our privacy policy. We'll never share your information.
                  </p>
                </div>
              </div>
            </form>
          </div>

          <!-- Column 3: Contact Details - Enhanced with better visual hierarchy -->
          <div class="space-y-8">
            <div class="bg-linear-to-br from-slate-900 to-slate-800 rounded-3xl p-8 shadow-xl relative overflow-hidden">
              <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500 rounded-full filter blur-3xl opacity-10"></div>
              <div class="relative">
                <div class="inline-flex items-center gap-2 bg-white/10 rounded-full px-4 py-2 mb-6">
                  <span class="text-blue-400 text-sm font-medium">📍 Get in Touch</span>
                </div>
                <h3 class="text-2xl font-bold text-white mb-6">Contact Details</h3>
                <div class="space-y-6">
                  <div class="flex items-start gap-4 group">
                    <div class="bg-blue-600 p-3 rounded-xl group-hover:scale-110 transition-transform">
                      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      </svg>
                    </div>
                    <div>
                      <p class="text-slate-300 text-sm font-medium mb-1">Warehouse Address</p>
                      <p class="text-white text-sm leading-relaxed">{contactInfo.address}</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-4 group">
                    <div class="bg-blue-600 p-3 rounded-xl group-hover:scale-110 transition-transform">
                      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                      </svg>
                    </div>
                    <div>
                      <p class="text-slate-300 text-sm font-medium mb-1">Email Us</p>
                      <a href={`mailto:${contactInfo.email}`} class="text-white text-sm hover:text-blue-400 transition-colors">{contactInfo.email}</a>
                    </div>
                  </div>
                  <div class="flex items-center gap-4 group">
                    <div class="bg-blue-600 p-3 rounded-xl group-hover:scale-110 transition-transform">
                      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                      </svg>
                    </div>
                    <div>
                      <p class="text-slate-300 text-sm font-medium mb-1">Call Us</p>
                      <span class="text-white text-sm">{contactInfo.phone}</span>
                    </div>
                  </div>
                </div>

                <div class="mt-10 pt-8 border-t border-slate-700">
                  <h4 class="font-bold text-white mb-3 flex items-center gap-2">
                    <span>⏰</span> Warehouse Hours
                  </h4>
                  <p class="text-slate-300 text-sm">{contactInfo.hours}</p>
                  <p class="text-slate-500 text-xs mt-2">Weekends: Closed (Appointments only)</p>
                </div>
              </div>
            </div>

            <!-- Trade Badge - Enhanced -->
            <div class="bg-linear-to-r from-blue-50 to-indigo-50 border border-blue-100 rounded-2xl p-6">
              <div class="flex items-start gap-3">
                <div class="text-2xl">🏢</div>
                <div>
                  <h4 class="text-blue-900 font-bold mb-2 uppercase text-xs tracking-widest">B2B Trade Only</h4>
                  <p class="text-blue-700 text-sm leading-relaxed">
                    We are a wholesale-only distributor. Please include your company registration number in the message for faster account approval.
                  </p>
                </div>
              </div>
            </div>

            <!-- Response Time Badge -->
            <div class="bg-slate-100 rounded-2xl p-6 text-center">
              <div class="text-3xl mb-2">⚡</div>
              <p class="text-slate-600 text-sm font-medium">Average response time</p>
              <p class="text-slate-900 text-2xl font-bold">Under 24h</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. MAP SECTION - Enhanced with better styling -->
    <section id="map" class="relative bg-slate-900">
      <div class="absolute inset-0 bg-linear-to-t from-slate-900 via-transparent to-transparent pointer-events-none z-10 h-32 top-0"></div>
      <div class="h-112.5 w-full">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2440.0631628109314!2d0.4851253770425717!3d52.3421299491799!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47d86f9160533e4b%3A0xc6b62145396594d2!2sJames%20Carter%20Rd%2C%20Mildenhall%2C%20Bury%20Saint%20Edmunds%20IP28%207DE!5e0!3m2!1sen!2suk!4v1700000000000!5m2!1sen!2suk" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          class="filter brightness-90 contrast-110"
        ></iframe>
      </div>
      <div class="absolute bottom-0 inset-x-0 bg-linear-to-t from-slate-900 via-transparent to-transparent pointer-events-none z-10 h-32"></div>
    </section>

    <!-- 4. FAQ SECTION - New addition for better user support -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-flex items-center gap-2 bg-slate-100 rounded-full px-4 py-2 mb-6">
          <span class="text-slate-600 text-sm font-medium">❓ Frequently Asked</span>
        </div>
        <h2 class="text-3xl font-bold text-slate-900 mb-12">Quick Answers</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left">
          <div class="p-6 bg-slate-50 rounded-2xl">
            <h3 class="font-bold text-slate-900 mb-2">Do you sell to the public?</h3>
            <p class="text-slate-600 text-sm">We are a B2B wholesale distributor. All sales require a valid business registration.</p>
          </div>
          <div class="p-6 bg-slate-50 rounded-2xl">
            <h3 class="font-bold text-slate-900 mb-2">What is your minimum order?</h3>
            <p class="text-slate-600 text-sm">Minimum order quantities vary by product category. Contact us for specific details.</p>
          </div>
          <div class="p-6 bg-slate-50 rounded-2xl">
            <h3 class="font-bold text-slate-900 mb-2">Do you offer delivery?</h3>
            <p class="text-slate-600 text-sm">Yes, we deliver across the UK with competitive shipping rates for bulk orders.</p>
          </div>
          <div class="p-6 bg-slate-50 rounded-2xl">
            <h3 class="font-bold text-slate-900 mb-2">Can I visit the warehouse?</h3>
            <p class="text-slate-600 text-sm">Yes, warehouse visits are available by appointment. Please use the form to schedule.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>